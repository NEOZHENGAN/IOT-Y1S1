// --- PINS ---
#define PIN_RELAY_LED    26   // Relay 1: Grow Light
#define PIN_RELAY_PUMP   14   // Relay 2: Water Pump
#define PIN_RELAY_HEAT   25   // Relay 3: Heating Pad

#define PIN_LDR          34   // LDR Sensor (Input)
#define PIN_MOISTURE     35   // Moisture Sensor (Input)

// --- SETTINGS ---
int lightThreshold = 1300;   // < 1300 (Dark) -> Light ON
int dryThreshold = 3000;     // > 3000 (Dry)  -> Pump ON

// --- RELAY LOGIC (FIXED) ---
int RELAY_ON = HIGH;      
int RELAY_OFF = LOW;

// --- VARIABLES ---
bool pumpMasterSwitch = false; // Starts OFF (Pump is disabled by default)
bool ledMasterSwitch = false;  // Starts OFF (LED is disabled by default)

BlynkTimer timer;

// --- AUTOMATION LOOP (Runs every 1 second) ---
void myTimerEvent()
{
  // 1. Read Sensors
  int ldrValue = analogRead(PIN_LDR);

  // --- 【新增：FOR LOOP】使用 for 循环计算土壤湿度的平均值（去噪滤波） ---
  int totalMoisture = 0;
  for (int i = 0; i < 10; i++) {
    totalMoisture = totalMoisture + analogRead(PIN_MOISTURE);
    delay(10); // 每次读取间隔 10 毫秒
  }
  int moistureValue = totalMoisture / 10; // 计算 10 次的平均值
  // -------------------------------------------------------------------------

  // 2. Send Data to App
  Blynk.virtualWrite(V0, ldrValue);      
  Blynk.virtualWrite(V4, moistureValue);    

  Serial.print("Light: "); Serial.print(ldrValue);
  Serial.print(" | Soil: "); Serial.println(moistureValue); // 修复了换行问题

  // --- JOB A: LIGHT CONTROL (Auto) ---
  if (ledMasterSwitch == true)
  {
    if (ldrValue < lightThreshold)
    {
      digitalWrite(PIN_RELAY_LED, RELAY_ON);
      Serial.println(" -> Dark: LED ON");
    }
    else
    {
      digitalWrite(PIN_RELAY_LED, RELAY_OFF);
      Serial.println(" -> Bright: LED OFF");
    }
  }
  else
  {
    // 修复 Bug：原来这里写成了 PIN_LDR，已修复为 PIN_RELAY_LED
    digitalWrite(PIN_RELAY_LED, RELAY_OFF);
    Serial.println(" -> LED is OFF (Master Switch Disabled)");
  }

  // --- JOB B: PUMP CONTROL (With Master Switch Logic) ---
  if (pumpMasterSwitch == true) 
  {
    if (moistureValue > dryThreshold) {
      digitalWrite(PIN_RELAY_PUMP, RELAY_ON);
      Serial.println(" -> Soil Dry: PUMP ON");
    } else {
      digitalWrite(PIN_RELAY_PUMP, RELAY_OFF);
      Serial.println(" -> Soil Wet: PUMP OFF");
    }
  } 
  else 
  {
    digitalWrite(PIN_RELAY_PUMP, RELAY_OFF);
    Serial.println(" -> Pump Disabled (Master Switch OFF)");
  }
  Serial.println("----------------------------------------");
}

// --- JOB D: MANUAL HEATER CONTROL (Button V6) ---
BLYNK_WRITE(V6)
{
  int btnValue = param.asInt(); 
  if (btnValue == 1) {
    digitalWrite(PIN_RELAY_HEAT, RELAY_ON); 
    Serial.println(" -> Manual: HEATER ON");
  } else {
    digitalWrite(PIN_RELAY_HEAT, RELAY_OFF); 
    Serial.println(" -> Manual: HEATER OFF");
  }
}

// --- JOB E: PUMP MASTER SWITCH (Button V8) ---
BLYNK_WRITE(V8)
{
  int btnValue = param.asInt();
  if (btnValue == 1) {
    pumpMasterSwitch = true;
    Serial.println("PUMP SYSTEM: ENABLED");
  } else {
    pumpMasterSwitch = false;
    Serial.println("PUMP SYSTEM: DISABLED");
    digitalWrite(PIN_RELAY_PUMP, RELAY_OFF); 
  }
}

// --- JOB F: LED MASTER SWITCH (Button V10) ---
BLYNK_WRITE(V10)
{
  int btnValue = param.asInt();
  if (btnValue == 1) {
    ledMasterSwitch = true;
    Serial.println("LED SYSTEM: ENABLED");
  } else {
    ledMasterSwitch = false;
    Serial.println("LED SYSTEM: DISABLED");
    digitalWrite(PIN_RELAY_LED, RELAY_OFF); 
  }
}

void setup()
{
  Serial.begin(9600);
  
  pinMode(PIN_RELAY_LED, OUTPUT);
  pinMode(PIN_RELAY_PUMP, OUTPUT);
  pinMode(PIN_RELAY_HEAT, OUTPUT); 
  
  pinMode(PIN_LDR, INPUT);
  pinMode(PIN_MOISTURE, INPUT);
  
  // Start with everything OFF
  digitalWrite(PIN_RELAY_LED, RELAY_OFF); 
  digitalWrite(PIN_RELAY_PUMP, RELAY_OFF);
  digitalWrite(PIN_RELAY_HEAT, RELAY_OFF);

  Serial.println("Connecting to Blynk...");
  Blynk.begin(BLYNK_AUTH_TOKEN, ssid, pass);

  // --- 【新增：WHILE LOOP】系统开机自检与 LED 预热闪烁 ---
  Serial.print("System Calibrating & Warming Up ");
  int bootTimer = 0;
  
  while (bootTimer < 6) {
    Serial.print(".");  
    
    // 让植物灯闪烁 3 次，提示硬件一切正常
    if (bootTimer % 2 == 0) {
      digitalWrite(PIN_RELAY_LED, RELAY_ON);
    } else {
      digitalWrite(PIN_RELAY_LED, RELAY_OFF);
    }
    
    delay(500); // 每次循环等半秒
    bootTimer++; // 计数器加 1
  }
  Serial.println(" Done!");
  digitalWrite(PIN_RELAY_LED, RELAY_OFF); // 确保预热结束后灯是关的
  // ----------------------------------------------------------------

  timer.setInterval(1000L, myTimerEvent);
  
  // Reset Buttons to OFF when ESP starts
  Blynk.virtualWrite(V6, 0); // Heater
  Blynk.virtualWrite(V8, 0); // Pump Master Switch
  Blynk.virtualWrite(V10, 0); // LED Master Switch
  
  Serial.println("System Ready! Running Automation...");
  Serial.println("----------------------------------------");
}

void loop()
{
  Blynk.run();
  timer.run();
}
